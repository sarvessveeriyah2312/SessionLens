{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["electron/*"]
    },
    "outDir": "out/main"
  },
  "include": [
    "electron.vite.config.*",
    "electron/**/*"
  ]
}
